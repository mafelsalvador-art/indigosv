<script>
  // Nav scroll
  window.addEventListener('scroll', () => {
    document.getElementById('nav').classList.toggle('scrolled', scrollY > 60);
  });

  // Mobile nav
  function toggleNav() {
    document.getElementById('navLinks').classList.toggle('open');
  }

  // Tabs
  function setTab(el) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    el.classList.add('active');
  }

  // Booking submit → WhatsApp
  function submitBooking() {
    const from = document.querySelector('.booking-form input[placeholder*="hotel"]').value || 'No especificado';
    const to   = document.querySelector('.booking-form input[placeholder*="Destino"]').value || 'No especificado';
    const msg  = `Hola Indigo SV! Quiero reservar un traslado:\n\n📍 Desde: ${from}\n🏁 Hasta: ${to}\n\nPor favor confirmenme disponibilidad y precio.`;
    window.open(`https://wa.me/50300000000?text=${encodeURIComponent(msg)}`, '_blank');
  }

  // Animate on scroll
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.service-card, .why-item, .route-card, .stat').forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(24px)';
    el.style.transition = 'opacity .6s ease, transform .6s ease';
    io.observe(el);
  });
</script>
